# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Maps (Places API) — address autocomplete on quote form
# Console: enable "Maps JavaScript API" + "Places API", restrict key to your domains
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Stripe TEST keys from https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_DEPOSIT_AMOUNT_CENTS=15000

# ── Lead delivery: Telegram + Quo (OpenPhone) ─────────────────
# Telegram: @BotFather → bot token; add bot to group; get chat_id via getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Quo (formerly OpenPhone): Settings → API
# https://www.quo.com/docs/mdx/api-reference/send-your-first-message
QUO_API_KEY=
# Business number in E.164, e.g. +14075550198
QUO_FROM_NUMBER=
# Optional — send as a specific workspace user (from GET /v1/phone-numbers)
QUO_USER_ID=
# Optional — SMS a copy of each lead to your cell (E.164)
QUO_OWNER_NOTIFY_NUMBER=
